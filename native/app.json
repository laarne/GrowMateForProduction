{
  "expo": {
    "name": "GrowMate",
    "slug": "growmate-native",
    "scheme": "growmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/growmate-logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.laarne.growmate",
      "adaptiveIcon": {
        "backgroundColor": "#F7FBF1",
        "foregroundImage": "./assets/growmate-logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/growmate-logo.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "9c7d0636-f9fb-4a97-907a-0d78e4d1bc76"
      }
    },
    "owner": "johnmichael.beringuel"
  }
}
